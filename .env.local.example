# Supabase (app state — persists eval runs + steps)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Gemini (powers the eval agent — used by @ai-sdk/google)
GOOGLE_GENERATIVE_AI_API_KEY=

# GitHub (target app repo — agent reads prompt/evals, creates PRs)
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BASE_PATH=frontend

# ClickHouse (production logs — agent scans these)
CLICKHOUSE_URL=
CLICKHOUSE_USER=
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=

# Nimble (web search for grounding judge verdicts)
NIMBLE_API_KEY=

# Datadog (optional — agent observability)
DD_API_KEY=
